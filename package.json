{
  "name": "designforge-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:sync": "prisma db push && prisma generate",
    "dev": "next dev --webpack",
    "dev:turbo": "next dev",
    "dev:fresh": "node -e \"try{require('fs').rmSync('.next',{recursive:true})}catch(e){}\" && next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "npm run typecheck",
    "db:migrate": "prisma migrate dev --name init",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "ts-node --project prisma/seed/tsconfig.json prisma/seed/index.ts",
    "templates:scrape": "ts-node -r tsconfig-paths/register scripts/scrapeTemplates.ts",
    "patterns:seed": "ts-node -r tsconfig-paths/register scripts/seedPatterns.ts",
    "db:generate-previews": "ts-node --project prisma/seed/tsconfig.json prisma/seed/generatePreviews.ts",
    "thumbnails:backfill": "ts-node scripts/generateMissingThumbnails.ts",
    "db:backfill-dimensions": "ts-node scripts/backfillDimensions.ts",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "typecheck": "tsc --noEmit",
    "worker:v1-gen": "npx tsx src/scripts/v1GenerationWorker.ts",
    "test": "vitest run",
    "plugin:build": "cd plugins/figma && npm install && npm run build",
    "plugin:dev": "cd plugins/figma && npm install && webpack --config webpack.ui.js --watch",
    "plugin:test": "cd plugins/figma && npm install && npm test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@auth/prisma-adapter": "^2.11.1",
    "@google/generative-ai": "^0.24.1",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^6.19.2",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "archiver": "^7.0.1",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.3.3",
    "ioredis": "^5.10.0",
    "langsmith": "^0.5.13",
    "lucide-react": "^0.577.0",
    "mime-types": "^3.0.2",
    "next": "16.2.0",
    "next-auth": "^5.0.0-beta.30",
    "node-cron": "^4.2.1",
    "node-html-parser": "^7.1.0",
    "nodemailer": "^7.0.13",
    "react": "19.2.4",
    "react-colorful": "^5.6.1",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.71.2",
    "recharts": "^3.8.0",
    "sharp": "^0.34.4",
    "tailwind-merge": "^3.5.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/jsdom": "^28.0.0",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/ui": "^4.1.0",
    "cheerio": "^1.2.0",
    "jsdom": "^29.0.0",
    "node-fetch": "^3.3.2",
    "postcss": "^8.5.8",
    "prisma": "^6.19.2",
    "puppeteer": "^24.40.0",
    "tailwindcss": "^4.2.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
